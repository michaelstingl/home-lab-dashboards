{
  "name": "home-lab-dashboards",
  "version": "1.0.0",
  "description": "Grafana dashboards as TypeScript code (Grafana Foundation SDK)",
  "scripts": {
    "build": "bun run build:vw-id7 && bun run build:vw-id3 && bun run build:vw-detail && bun run build:fems && bun run build:detail && bun run build:mlx && bun run build:esprimo",
    "build:vw-id7": "bun src/vw-id.ts id7 > dist/vw-id7.json",
    "build:vw-id3": "bun src/vw-id.ts id3 > dist/vw-id3.json",
    "build:vw-detail": "bun src/vw-id-detail.ts > dist/vw-id-detail.json",
    "build:fems": "bun src/fems-energy.ts > dist/fems-energy.json",
    "build:detail": "bun src/fems-detail.ts > dist/fems-detail.json",
    "build:mlx": "bun src/mlx-inference.ts > dist/mlx-inference.json",
    "build:esprimo": "bun src/esprimo-health.ts > dist/esprimo-health.json",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@grafana/grafana-foundation-sdk": "^11.6.0-cogv0.0.x.1753977659"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "typescript": "^5.9.3"
  }
}
